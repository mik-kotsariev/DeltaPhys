# ── Етап: продакшн-образ ──
FROM node:18-alpine

# Робоча директорія всередині контейнера
WORKDIR /app

# Копіюємо маніфести залежностей окремо для кешування шару
COPY package.json package-lock.json ./

# Встановлюємо тільки продакшн-залежності
RUN npm ci --omit=dev

# Копіюємо вихідний код застосунку
COPY . .

# Порт, на якому слухає Express
EXPOSE 3000

# Запуск серверу
CMD ["node", "server.js"]
